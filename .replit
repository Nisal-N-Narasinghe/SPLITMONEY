modules = ["php-8.2", "nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "php artisan serve --host=0.0.0.0 --port=5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "npm run build && php artisan migrate --force && php artisan serve --host=0.0.0.0 --port=5000"]

[userenv]

[userenv.shared]
GEMINI_MODEL = "gemini-2.5-flash"
GEMINI_TIMEOUT = "30"
APP_NAME = "SplitMoney"
APP_ENV = "local"
APP_DEBUG = "true"
APP_URL = "https://3a7d60be-bd3f-4249-b49f-9f64f5331c12-00-itdoxw598o0v.kirk.replit.dev"
LOG_CHANNEL = "stack"
LOG_STACK = "single"
LOG_LEVEL = "debug"
DB_CONNECTION = "pgsql"
SESSION_DRIVER = "database"
SESSION_LIFETIME = "120"
CACHE_STORE = "database"
QUEUE_CONNECTION = "database"
BROADCAST_CONNECTION = "log"
FILESYSTEM_DISK = "local"
MAIL_MAILER = "log"
VITE_APP_NAME = "SplitMoney"
